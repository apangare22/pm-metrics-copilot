# ── Client (Vite) ─────────────────────────────────────────────────────────────
# These are embedded in the browser bundle. The Supabase *anon* key is meant to
# be public; Row Level Security on your tables protects user data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Server only (Vercel Function: api/analyze.ts) ───────────────────────────
# Never prefix secrets with VITE_ — that exposes them to anyone who loads your site.
# Use the SAME Supabase URL and anon key values as above (different variable names
# so only non-VITE names are available to the serverless runtime).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
ANTHROPIC_API_KEY=sk-ant-api03-...
